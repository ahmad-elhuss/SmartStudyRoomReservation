<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="smartstudyroomreservation.controller.MyReservationsController"
      alignment="CENTER" spacing="15" prefWidth="650" prefHeight="500">

    <padding>
        <Insets top="30" right="40" bottom="30" left="40"/>
    </padding>

    <Label text="My Reservations" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>

    <ListView fx:id="reservationsListView" prefHeight="380" />

    <Button text="Refresh" fx:id="refreshButton" prefWidth="200" onAction="#handleRefresh"/>
    <Button text="Back to Home" fx:id="backButton" prefWidth="200" onAction="#handleBackToHome"/>

</VBox>